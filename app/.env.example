NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1


DB_HOST=localhost                    
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USER=ecommerce_admin
DB_PASSWORD=SecurePassword123!
DB_DIALECT=mysql                      
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_LOGGING=false                      


JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d


AWS_REGION=us-east-1
AWS_SECRET_NAME=ecommerce-cloud-native-sandbox/database/credentials


PAYMENT_SERVICE_URL=http://localhost:3001
PAYMENT_SERVICE_API_KEY=fictional_api_key_12345
PAYMENT_SUCCESS_RATE=0.95            


LOG_LEVEL=info                         
LOG_FORMAT=json                     

CORS_ORIGIN=http://localhost:8080